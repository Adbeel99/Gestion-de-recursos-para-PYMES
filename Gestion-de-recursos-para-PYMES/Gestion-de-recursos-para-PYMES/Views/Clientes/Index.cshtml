@model IEnumerable<Gestion_de_recursos_para_PYMES.Models.Cliente>

<h2>Clientes</h2>
<p><a asp-action="Create">Nuevo cliente</a></p>

<table class="table">
    <thead>
        <tr><th>Nombre</th><th>Apellido</th><th>Empresa</th><th>Email</th><th>Teléfono</th><th>Dirección</th><th>Fecha</th></tr>
    </thead>
    <tbody>
    @foreach(var c in Model) {
        <tr>
            <td>@c.Nombre</td><td>@c.Apellido</td><td>@c.Empresa</td><td>@c.Email</td><td>@c.Telefono</td><td>@c.Direccion</td><td>@c.FechaRegistro.ToString("g")</td>
        </tr>
    }
    </tbody>
</table>