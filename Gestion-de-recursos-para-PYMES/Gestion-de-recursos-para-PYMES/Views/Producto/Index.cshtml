@model List<Gestion_de_recursos_para_PYMES.Models.Producto>
@{
    ViewData["Title"] = "Productos";
}

<h2 class="mb-3">Productos</h2>
<a asp-action="Crear" class="btn btn-success mb-3">+ Registrar nuevo producto</a>

<table class="table table-striped">
    <thead>
        <tr>
            <th>SKU</th>
            <th>Nombre</th>
            <th>Categoría</th>
            <th>Precio Venta</th>
            <th>Existencias</th>
            <th>Estado</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var producto in Model)
        {
            <tr>
                <td>@producto.CodigoSKU</td>
                <td>@producto.Nombre</td>
                <td>@producto.Categoria?.Nombre</td>
                <td>@producto.PrecioVenta.ToString("C")</td>
                <td>@producto.Existencias</td>
                <td>
                    @if (producto.Existencias <= producto.ExistenciasMinimas)
                    {
                        <span class="badge bg-danger">Stock Bajo</span>
                    }
                    else
                    {
                        <span class="badge bg-success">OK</span>
                    }
                </td>
                <td>
                    <a asp-action="Detalle"
                           asp-route-id="@producto.ProductoId"
                           class="btn btn-primary btn-sm">
                        Ver detalle
                    </a>
                </td>
            </tr>
        }
    </tbody>
</table>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    @if (ViewBag.AlertaStock != null)
    {
        <script>
            Swal.fire({
            icon: 'warning',
            title: 'Alerta de Stock Bajo',
            html: `Los siguientes productos están en stock mínimo o por debajo:<br><br>
            <ul style="text-align:left">
            @foreach (var nombre in ViewBag.AlertaStock)
            {
                @:<li>@nombre</li>
            }
            </ul>`,
            confirmButtonText: 'Entendido'
            });
        </script>
    }
}