@model List<Gestion_de_recursos_para_PYMES.Models.Producto>
@{
    ViewData["Title"] = "Productos";
}

<h2 class="mb-3">Productos</h2>

<a asp-action="Crear" class="btn btn-success mb-3">
    + Registrar nuevo producto
</a>

<!-- 🔍 BUSCADOR -->
<div class="mb-3">
    <input type="text" id="busqueda" class="form-control" placeholder="Buscar producto..." />
</div>

<table class="table table-striped">
    <thead>
        <tr>
            <th>SKU</th>
            <th>Nombre</th>
            <th>Categoría</th>
            <th>Precio Venta</th>
            <th>Existencias</th>
            <th></th>
        </tr>
    </thead>
    <tbody id="tablaProductos">
        @foreach (var producto in Model)
        {
            <tr>
                <td>@producto.CodigoSKU</td>
                <td>@producto.Nombre</td>
                <td>@producto.Categoria?.Nombre</td>
                <td>@producto.PrecioVenta</td>
                <td>@producto.Existencias</td>
                <td>
                    <a asp-action="Detalle"
                           asp-route-id="@producto.ProductoId"
                           class="btn btn-primary btn-sm">
                        Ver detalle
                    </a>
                </td>
            </tr>
        }
    </tbody>
</table>

@section Scripts {
    <script>
        const input = document.getElementById("busqueda");
        const tabla = document.getElementById("tablaProductos");

        input.addEventListener("keyup", async () => {
            const termino = input.value;

            const response = await fetch(`/producto/buscar?termino=${termino}`);
            const data = await response.json();

            tabla.innerHTML = "";

            if (data.length === 0) {
                tabla.innerHTML = `
                    <tr>
                        <td colspan="6" class="text-center text-muted">
                            No se encontraron productos
                        </td>
                    </tr>
                `;
                return;
            }

            data.forEach(p => {
                tabla.innerHTML += `
                    <tr>
                        <td>${p.codigoSKU ?? ""}</td>
                        <td>${p.nombre ?? ""}</td>
                        <td>${p.categoria?.nombre ?? ""}</td>
                        <td>${p.precioVenta ?? ""}</td>
                        <td>${p.existencias ?? ""}</td>
                        <td>
                            <a href="/producto/detalle/${p.productoId}"
                               class="btn btn-primary btn-sm">
                               Ver detalle
                            </a>
                        </td>
                    </tr>
                `;
            });
        });
    </script>
}