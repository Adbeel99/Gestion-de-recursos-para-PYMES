@{
    ViewData["Title"] = "Panel Principal";
}

<div class="text-center">
    <h1 class="fw-bold">Sistema de Gestión PYMES</h1>
    <p class="text-muted">
        Plataforma interna para administración de recursos empresariales.
    </p>

    @if (User.Identity.IsAuthenticated)
    {
        <div class="mt-4">
            <h4>Bienvenido, @User.Identity.Name</h4>

            @if (User.IsInRole("Administrador"))
            {
                <span class="badge bg-warning text-dark">
                    Rol: Administrador
                </span>
            }
            else if (User.IsInRole("Vendedor"))
            {
                <span class="badge bg-info text-dark">
                    Rol: Vendedor
                </span>
            }
        </div>
    }
    else
    {
        <p class="mt-3">
            Inicie sesión para acceder al sistema.
        </p>
    }
</div>