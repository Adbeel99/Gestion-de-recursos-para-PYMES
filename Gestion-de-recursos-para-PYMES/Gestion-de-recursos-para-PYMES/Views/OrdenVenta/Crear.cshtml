@model Gestion_de_recursos_para_PYMES.Models.OrdenVentaViewModel
@{
    ViewData["Title"] = "Nueva Orden de Venta";
}

<h2 class="mb-3">Nueva Orden de Venta</h2>

@using (Html.BeginForm("Crear", "OrdenVenta", FormMethod.Post, new { @class = "row g-3" }))
{
    @Html.AntiForgeryToken()

    <div class="col-md-6">
        @Html.LabelFor(m => m.ClienteId, "Cliente", new { @class = "form-label" })
        @Html.DropDownListFor(m => m.ClienteId,
            Model.Clientes,
            "Seleccione cliente",
            new { @class = "form-select" })
        @Html.ValidationMessageFor(m => m.ClienteId, "", new { @class = "text-danger" })
    </div>

    <div class="col-12">
        <h5>Productos</h5>
        <div class="row g-2 mb-2">
            <div class="col-md-5">
                <select id="productoSelect" class="form-select">
                    <option value="" data-stock="0">Seleccione producto</option>
                    @foreach (var p in Model.Productos)
                    {
                        <option value="@p.Value" data-stock="@p.Value">@p.Text</option>
                    }
                </select>
            </div>
            <div class="col-md-3">
                <div class="input-group">
                    <button type="button" class="btn btn-outline-secondary" onclick="decrementar()">-</button>
                    <input type="number" id="cantidadInput" class="form-control text-center" value="1" min="1" />
                    <button type="button" class="btn btn-outline-secondary" onclick="incrementar()">+</button>
                </div>
            </div>
            <div class="col-md-4">
                <button type="button" class="btn btn-success w-100" onclick="agregarProducto()">
                    + Agregar
                </button>
            </div>
        </div>

        <table class="table table-striped">
            <thead>
                <tr>
                    <th>Producto</th>
                    <th>Stock disponible</th>
                    <th>Cantidad</th>
                    <th></th>
                </tr>
            </thead>
            <tbody id="detallesBody"></tbody>
        </table>

        <div id="detallesHidden"></div>
    </div>

    <div class="col-12">
        <button type="submit" class="btn btn-primary">Guardar</button>
        @Html.ActionLink("Cancelar", "Index", "OrdenVenta", null, new { @class = "btn btn-secondary" })
    </div>
}

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        let detalles = [];
        let indice = 0;

        // Stock de productos desde el servidor
        const stockProductos = {
        @foreach (var p in Model.Productos)
        {
            @:"@p.Value": @(p.Text.Contains("Stock:") ? p.Text.Split("Stock:")[1].Replace(")", "").Trim() : "0"),
        }
        };

        function incrementar() {
        const input = document.getElementById('cantidadInput');
        input.value = parseInt(input.value) + 1;
        }

        function decrementar() {
        const input = document.getElementById('cantidadInput');
        if (parseInt(input.value) > 1)
        input.value = parseInt(input.value) - 1;
        }

        function agregarProducto() {
        const select = document.getElementById('productoSelect');
        const cantidadInput = document.getElementById('cantidadInput');
        const cantidad = parseInt(cantidadInput.value);

        if (!select.value) {
        Swal.fire({
        icon: 'warning',
        title: 'Atención',
        text: 'Debe seleccionar un producto'
        });
        return;
        }

        if (!cantidad || cantidad <= 0) {
        Swal.fire({
        icon: 'warning',
        title: 'Atención',
        text: 'La cantidad debe ser mayor a 0'
        });
        return;
        }

        const productoId = select.value;
        const productoNombre = select.options[select.selectedIndex].text;
        const stock = parseInt(stockProductos[productoId]) || 0;

        if (stock <= 0) {
        Swal.fire({
        icon: 'error',
        title: 'Sin stock',
        text: `El producto "${productoNombre}" no tiene stock disponible`
        });
        return;
        }

        if (cantidad > stock) {
        Swal.fire({
        icon: 'error',
        title: 'Stock insuficiente',
        text: `Solo hay ${stock} unidades disponibles de "${productoNombre}"`
        });
        return;
        }

        const existe = detalles.find(d => d.productoId === productoId);
        if (existe) {
        Swal.fire({
        icon: 'warning',
        title: 'Producto duplicado',
        text: 'Este producto ya fue agregado'
        });
        return;
        }

        detalles.push({ productoId, productoNombre, cantidad, stock });

        const tbody = document.getElementById('detallesBody');
        tbody.innerHTML += `<tr id="fila_${indice}">
        <td>${productoNombre}</td>
        <td>${stock}</td>
        <td>${cantidad}</td>
        <td>
        <button type="button" class="btn btn-danger btn-sm"
        onclick="eliminarFila(${indice}, '${productoId}')">
        Eliminar
        </button>
        </td>
        </tr>`;

        const hidden = document.getElementById('detallesHidden');
        hidden.innerHTML += `
        <input type="hidden" name="Detalles[${indice}].ProductoId" value="${productoId}" id="hidden_pid_${indice}" />
        <input type="hidden" name="Detalles[${indice}].Cantidad" value="${cantidad}" id="hidden_cant_${indice}" />
        `;

        indice++;
        select.value = '';
        cantidadInput.value = 1;
        }

        function eliminarFila(idx, productoId) {
        Swal.fire({
        icon: 'question',
        title: '¿Eliminar producto?',
        text: 'Se quitará este producto de la orden',
        showCancelButton: true,
        confirmButtonText: 'Sí, eliminar',
        cancelButtonText: 'Cancelar'
        }).then((result) => {
        if (result.isConfirmed) {
        document.getElementById(`fila_${idx}`).remove();
        document.getElementById(`hidden_pid_${idx}`).remove();
        document.getElementById(`hidden_cant_${idx}`).remove();
        detalles = detalles.filter(d => d.productoId !== productoId);
        }
        });
        }
    </script>
}