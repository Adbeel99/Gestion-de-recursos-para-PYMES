@model Gestion_de_recursos_para_PYMES.Models.CambiarRolViewModel
@{
    ViewData["Title"] = "Cambiar Rol";
}

<h2 class="mb-3">Cambiar Rol de Usuario</h2>

<div class="card shadow" style="max-width: 500px;">
    <div class="card-body">
        <p><strong>Nombre:</strong> @Model.Nombre @Model.Apellidos</p>
        <p><strong>Correo:</strong> @Model.Email</p>
        <p><strong>Rol actual:</strong> @Model.RolActual</p>

        <form action="/usuarios/cambiar-rol/@Model.UsuarioId" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="UsuarioId" value="@Model.UsuarioId" />
            <input type="hidden" name="Nombre" value="@Model.Nombre" />
            <input type="hidden" name="Apellidos" value="@Model.Apellidos" />
            <input type="hidden" name="Email" value="@Model.Email" />
            <input type="hidden" name="RolActual" value="@Model.RolActual" />

            <div class="mb-3">
                <label class="form-label">Nuevo Rol</label>
                <select name="NuevoRol" class="form-select">
                    <option value="Administrador">Administrador</option>
                    <option value="Vendedor">Vendedor</option>
                    <option value="Almacenista">Almacenista</option>
                </select>
            </div>

            <button type="submit" class="btn btn-success">Guardar</button>
            @Html.ActionLink("Cancelar", "Index", "Usuario", null, new { @class = "btn btn-secondary" })
        </form>
    </div>
</div>