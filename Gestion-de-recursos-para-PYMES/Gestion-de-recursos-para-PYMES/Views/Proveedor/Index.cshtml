@model List<Gestion_de_recursos_para_PYMES.Models.Proveedor>
@{
    ViewData["Title"] = "Proveedores";
}

<h2 class="mb-3">Proveedores</h2>
<a asp-action="Crear" class="btn btn-success mb-3">+ Registrar nuevo proveedor</a>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Nombre</th>
            <th>Teléfono</th>
            <th>Correo</th>
            <th>Descripción</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var proveedor in Model)
        {
            <tr>
                <td>@proveedor.Nombre</td>
                <td>@proveedor.Telefono</td>
                <td>@proveedor.Correo</td>
                <td>@proveedor.Descripcion</td>
                <td>
                    <a asp-action="Detalle"
                       asp-route-id="@proveedor.ProveedorId"
                       class="btn btn-primary btn-sm">
                        Ver detalle
                    </a>
                </td>
            </tr>
        }
    </tbody>
</table>