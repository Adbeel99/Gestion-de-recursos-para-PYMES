@page
@model LoginModel

@{
    ViewData["Title"] = "Iniciar Sesión";
}

<div class="row justify-content-center">
    <div class="col-md-5">

        <div class="card shadow-lg border-0">
            <div class="card-body p-4">

                <h3 class="text-center mb-4">Sistema de Gestión PYMES</h3>
                <p class="text-center text-muted mb-4">Ingrese sus credenciales para continuar</p>

                <form id="account" method="post">

                    <div asp-validation-summary="ModelOnly" class="text-danger text-center"></div>

                    <div class="form-floating mb-3">
                        <input asp-for="Input.Email" class="form-control" placeholder="correo@empresa.com" />
                        <label asp-for="Input.Email">Correo Electrónico</label>
                        <span asp-validation-for="Input.Email" class="text-danger"></span>
                    </div>

                    <div class="form-floating mb-3">
                        <input asp-for="Input.Password" class="form-control" placeholder="Contraseña" />
                        <label asp-for="Input.Password">Contraseña</label>
                        <span asp-validation-for="Input.Password" class="text-danger"></span>
                    </div>

                    <div class="form-check mb-3">
                        <input class="form-check-input" asp-for="Input.RememberMe" />
                        <label class="form-check-label" asp-for="Input.RememberMe">
                            Recordarme
                        </label>
                    </div>

                    <button type="submit" class="w-100 btn btn-dark btn-lg">
                        Iniciar Sesión
                    </button>

                    <div class="text-center mt-3">
                        <a asp-page="./Register">Crear nueva cuenta</a>
                    </div>

                </form>

            </div>
        </div>

    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}